---
import Base from '../layouts/Base.astro';
import VariantSwitcher from '../components/VariantSwitcher.astro';
import { asset, isTodo } from '../lib/asset';
import { loadSite } from '../lib/content';

const s = await loadSite();
const h = s.hero;
const FONTS =
  'https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=DM+Sans:wght@400;500;700&display=swap';
---

<Base title="Алхимия красоты · вариант C «Тактильный нюд»" description={h.subtitle} fonts={FONTS}>
  <VariantSwitcher current="c" />

  <header class="hdr">
    <div class="wrap hdr-in">
      <div class="logo">Алхимия <i>красоты</i></div>
      <nav class="nav">
        <a href="#program">Программа</a>
        <a href="#experts">Эксперты</a>
        <a href="#format">Формат</a>
        <a href="#tariffs">Стоимость</a>
      </nav>
      <a class="btn" href="#cta">Забронировать</a>
    </div>
  </header>

  <!-- HERO -->
  <div class="hero">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">✦ {h.eyebrow}</span>
        <h1>{h.titleMain} <i>{h.titleAccent}</i> {h.titleTail}</h1>
        <p class="sub">{h.subtitle}</p>
        <div class="hero-cta">
          <a class="btn btn-lg" href="#cta">{h.ctaPrimary}</a>
          <a class="btn btn-o btn-lg" href="#program">{h.ctaSecondary}</a>
        </div>
        <div class="hero-trust">
          {h.trust?.map((t) => <span class="chip">{t}</span>)}
        </div>
      </div>
      <div class="hero-photo">
        <div class="frame">
          {!isTodo(h.photo) && <img src={asset(h.photo!)} alt={h.photoAlt ?? ''} />}
        </div>
        <div class="float f1"><b>Марина Баяндина</b><span>ведущий эксперт курса</span></div>
        <div class="float f2"><div class="n">32</div><span>года в медицине</span></div>
      </div>
    </div>
  </div>

  <!-- ЦИФРЫ -->
  <section class="nums">
    <div class="wrap nums-grid">
      {h.stats?.map((st) => (
        <div class="num" data-animate>
          <div class="num-v">{st.value}</div>
          <div class="num-l">{st.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- БОЛЬ -->
  <section id="problem">
    <div class="wrap">
      <div class="sec-head" data-animate>
        <span class="eyebrow">{s.problem.data.eyebrow}</span>
        <h2>{s.problem.data.title}</h2>
        <p>{s.problem.data.subtitle}</p>
      </div>
      <div class="md-list" data-animate><s.problem.Body /></div>
    </div>
  </section>

  <!-- ПРОГРАММА -->
  <section id="program">
    <div class="wrap">
      <div class="sec-head" data-animate>
        <span class="eyebrow">{s.blocksIntro.eyebrow}</span>
        <h2>{s.blocksIntro.title}</h2>
        <p>{s.blocksIntro.subtitle}</p>
      </div>
      <div class="cards">
        {s.blocks.map((b) => (
          <div class="card" data-animate>
            <div class="n">{String(b.data.order).padStart(2, '0')}</div>
            {b.data.tag && <span class="tag">{b.data.tag}</span>}
            <h3>{b.data.title}</h3>
            <div class="card-body"><b.Body /></div>
            {b.data.outcome && (
              <div class="outcome"><span class="lbl">На выходе</span>{b.data.outcome}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ЭКСПЕРТЫ -->
  <div class="ex-band" id="experts">
    <section>
      <div class="wrap">
        <div class="sec-head" data-animate>
          <span class="eyebrow">{s.expertsIntro.eyebrow}</span>
          <h2>{s.expertsIntro.title}</h2>
          <p>{s.expertsIntro.subtitle}</p>
        </div>
        <div class="ex-grid">
          {s.experts.map((e) => (
            <div class={'ex' + (e.data.lead ? ' lead-ex' : '')} data-animate>
              <div class="ph">
                {isTodo(e.data.photo)
                  ? <div class="ph-empty">Фото</div>
                  : <img src={asset(e.data.photo!)} alt={e.data.name} />}
              </div>
              {e.data.badge && <span class="badge">{e.data.badge}</span>}
              <h3>{e.data.name}</h3>
              {e.data.role && <div class="rl">{e.data.role}</div>}
              {e.data.blocks && <div class="ex-blocks">{e.data.blocks}</div>}
              {e.data.credentials && (
                <div class="creds">{e.data.credentials.map((c) => <span>{c}</span>)}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- ДЛЯ КОГО -->
  <section id="audience">
    <div class="wrap">
      <div class="sec-head" data-animate>
        <span class="eyebrow">{s.audience.data.eyebrow}</span>
        <h2>{s.audience.data.title}</h2>
        <p>{s.audience.data.subtitle}</p>
      </div>
      <div class="md-list" data-animate><s.audience.Body /></div>
    </div>
  </section>

  <!-- ФОРМАТ -->
  <section id="format">
    <div class="wrap">
      <div class="sec-head" data-animate>
        <span class="eyebrow">{s.format.eyebrow}</span>
        <h2>{s.format.title}</h2>
        <p>{s.format.subtitle}</p>
      </div>
      <div class="fmt" data-animate>
        {s.format.items?.map((it) => (
          <div class="fmt-row">
            <span class="lbl">{it.label}</span>
            <b class={isTodo(it.value) ? 'todo' : ''}>{it.value}</b>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ТАРИФЫ -->
  <section id="tariffs">
    <div class="wrap">
      <div class="sec-head" data-animate>
        <span class="eyebrow">{s.tariffsIntro.eyebrow}</span>
        <h2>{s.tariffsIntro.title}</h2>
        <p>{s.tariffsIntro.subtitle}</p>
      </div>
      <div class="tf-grid">
        {s.tariffs.map((t) => (
          <div class={'tf' + (t.badge ? ' featured' : '')} data-animate>
            {t.badge && <div class="tf-badge">{t.badge}</div>}
            <div class="tf-name">{t.name}</div>
            {t.limit && <div class={'tf-limit' + (isTodo(t.limit) ? ' todo' : '')}>{t.limit}</div>}
            <div class={'tf-price' + (isTodo(t.price) ? ' todo' : '')}>{t.price}</div>
            <ul class="tf-feats">{t.features.map((f) => <li>{f}</li>)}</ul>
            <a class={'btn ' + (t.badge ? '' : 'btn-o')} href="#cta">{t.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta">
    <div class="wrap">
      <div class="cta-in" data-animate>
        <span class="eyebrow light">Набор открыт</span>
        <h2>{s.cta.title}</h2>
        <p>{s.cta.subtitle}</p>
        <a class="btn btn-lg btn-light" href="#cta">{s.cta.button}</a>
        {s.cta.note && <div class="note">{s.cta.note}</div>}
      </div>
    </div>
  </section>

  <footer class="ftr">
    <div class="wrap">Алхимия красоты · Марина Баяндина · черновик на согласовании</div>
  </footer>
</Base>

<style is:global>
  :root {
    --skin: #f3e8df;
    --skin-2: #eadacc;
    --card: #fffcf9;
    --ink: #33241d;
    --ink-soft: #7a6459;
    --caramel: #a9694f;
    --caramel-2: #8a5039;
    --clay: #c98f76;
    --sage: #7e8a6b;
    --line: rgba(51, 36, 29, 0.12);
    --sh: 0 24px 60px -30px rgba(51, 36, 29, 0.45);
    --sh-sm: 0 14px 34px -22px rgba(51, 36, 29, 0.4);
    --maxw: 1200px;
    --r: 30px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    font-family: 'DM Sans', system-ui, sans-serif;
    background: var(--skin); color: var(--ink);
    font-size: 17px; line-height: 1.68; -webkit-font-smoothing: antialiased; overflow-x: hidden;
  }
  img { display: block; max-width: 100%; }
  a { color: inherit; }
  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 30px; }
  h1, h2, h3 {
    font-family: 'Fraunces', Georgia, serif; font-weight: 500; line-height: 1.04;
    letter-spacing: -0.02em; font-variation-settings: 'SOFT' 60, 'WONK' 1;
  }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 9px; font-weight: 700; font-size: 12px;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--caramel);
    background: rgba(169, 105, 79, 0.1); padding: 8px 16px; border-radius: 999px;
  }
  .eyebrow.light { background: rgba(255, 248, 243, 0.16); color: #fff8f3; }
  .lbl { font-weight: 700; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--clay); }
  .todo { color: var(--caramel) !important; }

  [data-animate] { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
  [data-animate].in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    [data-animate] { opacity: 1; transform: none; transition: none; }
  }

  .hdr { padding: 20px 0; }
  .hdr-in {
    display: flex; align-items: center; justify-content: space-between; gap: 20px;
    background: var(--card); border-radius: 999px; padding: 10px 12px 10px 26px; box-shadow: var(--sh-sm);
  }
  .logo { font-family: 'Fraunces', serif; font-size: 19px; font-weight: 600; white-space: nowrap; }
  .logo i { font-style: italic; color: var(--caramel); }
  .nav { display: flex; gap: 28px; }
  .nav a { color: var(--ink-soft); text-decoration: none; font-size: 14.5px; font-weight: 500; }
  .nav a:hover { color: var(--caramel); }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 9px;
    font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 15px;
    padding: 14px 28px; border-radius: 999px; background: var(--caramel); color: #fff8f3;
    text-decoration: none; border: 2px solid var(--caramel); cursor: pointer;
    transition: 0.25s; box-shadow: 0 12px 26px -14px rgba(169, 105, 79, 0.9); white-space: nowrap;
  }
  .btn:hover { background: var(--caramel-2); border-color: var(--caramel-2); transform: translateY(-2px); }
  .btn-o { background: transparent; color: var(--ink); border-color: rgba(51, 36, 29, 0.18); box-shadow: none; }
  .btn-o:hover { background: var(--card); border-color: var(--caramel); color: var(--caramel); }
  .btn-lg { padding: 18px 36px; font-size: 16px; }
  .btn-light { background: #fff8f3; color: var(--caramel-2); border-color: #fff8f3; }
  .btn-light:hover { background: var(--ink); border-color: var(--ink); color: #fff8f3; }

  /* HERO */
  .hero { padding: 44px 0 90px; position: relative; }
  .hero::before {
    content: ''; position: absolute; top: -120px; right: -160px; width: 620px; height: 620px;
    border-radius: 50%; pointer-events: none;
    background: radial-gradient(circle at 35% 35%, rgba(201, 143, 118, 0.5), rgba(201, 143, 118, 0) 68%);
  }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 56px; align-items: center; position: relative; }
  .hero h1 { font-size: clamp(42px, 5.6vw, 76px); margin: 24px 0 0; }
  .hero h1 i { font-style: italic; color: var(--caramel); }
  .hero .sub { font-size: 19px; color: var(--ink-soft); max-width: 46ch; margin: 26px 0 34px; }
  .hero-cta { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-trust { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 34px; }
  .chip { background: var(--card); border-radius: 999px; padding: 9px 18px; font-size: 13.5px; font-weight: 500; color: var(--ink-soft); box-shadow: var(--sh-sm); }
  .hero-photo { position: relative; }
  .hero-photo .frame { border-radius: 260px 260px 34px 34px; overflow: hidden; box-shadow: var(--sh); background: var(--skin-2); }
  .hero-photo img { width: 100%; height: 560px; object-fit: cover; object-position: 52% 18%; }
  .float { position: absolute; background: var(--card); border-radius: 22px; padding: 16px 20px; box-shadow: var(--sh-sm); }
  .float.f1 { left: -34px; bottom: 78px; }
  .float.f1 b { font-family: 'Fraunces', serif; font-size: 17px; display: block; }
  .float.f1 span { font-size: 13px; color: var(--ink-soft); }
  .float.f2 { right: -20px; top: 56px; display: flex; align-items: center; gap: 12px; }
  .float.f2 .n { font-family: 'Fraunces', serif; font-size: 30px; color: var(--caramel); line-height: 1; }
  .float.f2 span { font-size: 13px; color: var(--ink-soft); line-height: 1.35; max-width: 9ch; }

  section { padding: 96px 0; scroll-margin-top: 20px; }
  .sec-head { text-align: center; max-width: 720px; margin: 0 auto 60px; }
  .sec-head h2 { font-size: clamp(32px, 4.4vw, 54px); margin-top: 20px; }
  .sec-head p { color: var(--ink-soft); margin-top: 18px; font-size: 18px; }

  /* ЦИФРЫ */
  .nums { padding: 20px 0 80px; }
  .nums-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .num { background: var(--card); border-radius: var(--r); padding: 26px 24px; text-align: center; box-shadow: var(--sh-sm); }
  .num-v { font-family: 'Fraunces', serif; font-size: 46px; color: var(--caramel); line-height: 1; margin-bottom: 8px; }
  .num-l { font-size: 14px; color: var(--ink-soft); }

  /* СПИСКИ */
  .md-list ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .md-list li {
    background: var(--card); border-radius: 22px; padding: 22px 26px 22px 52px;
    position: relative; color: var(--ink-soft); font-size: 16px; box-shadow: var(--sh-sm);
  }
  .md-list li::before {
    content: '✦'; position: absolute; left: 22px; top: 21px; color: var(--clay); font-size: 14px;
  }
  .md-list strong { color: var(--ink); font-weight: 700; }

  /* ПРОГРАММА */
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .card { background: var(--card); border-radius: var(--r); padding: 32px 30px 34px; box-shadow: var(--sh-sm); transition: 0.28s; display: flex; flex-direction: column; }
  .card:hover { transform: translateY(-5px); box-shadow: var(--sh); }
  .card .n {
    font-family: 'Fraunces', serif; font-size: 15px; font-weight: 600; color: #fff8f3;
    background: var(--caramel); width: 38px; height: 38px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; margin-bottom: 20px;
  }
  .card:nth-child(1) .n, .card:nth-child(2) .n { background: var(--sage); }
  .card .tag { font-size: 12px; font-weight: 700; letter-spacing: 0.13em; text-transform: uppercase; color: var(--clay); margin-bottom: 10px; display: block; }
  .card h3 { font-size: 26px; margin-bottom: 12px; }
  .card-body { color: var(--ink-soft); font-size: 15.5px; flex: 1; }
  .card-body p + p { margin-top: 12px; }
  .outcome { margin-top: 18px; background: var(--skin); border-radius: 18px; padding: 14px 18px; font-size: 15px; }
  .outcome .lbl { display: block; margin-bottom: 5px; }

  /* ЭКСПЕРТЫ */
  .ex-band { background: var(--skin-2); border-radius: 48px; max-width: 1320px; margin: 0 auto; }
  .ex-grid { display: grid; grid-template-columns: 1.35fr 1fr 1fr 1fr; gap: 20px; align-items: start; }
  .ex { background: var(--card); border-radius: var(--r); padding: 22px 22px 26px; box-shadow: var(--sh-sm); }
  .ex.lead-ex { background: linear-gradient(165deg, #fffcf9, #f8ede4); }
  .ex .ph { border-radius: 22px; overflow: hidden; aspect-ratio: 1 / 1.08; margin-bottom: 18px; background: var(--skin-2); }
  .ex .ph img { width: 100%; height: 100%; object-fit: cover; object-position: 55% 28%; }
  .ph-empty {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #b9a395;
    background: repeating-linear-gradient(45deg, #efe1d6, #efe1d6 9px, #e7d6c8 9px, #e7d6c8 18px);
  }
  .ex .badge {
    display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--caramel); background: rgba(169, 105, 79, 0.12);
    border-radius: 999px; padding: 5px 12px; margin-bottom: 10px;
  }
  .ex h3 { font-size: 22px; margin-bottom: 6px; }
  .ex .rl { font-size: 14px; color: var(--ink-soft); line-height: 1.5; }
  .ex-blocks { font-size: 12.5px; color: var(--clay); margin-top: 10px; font-weight: 500; }
  .creds { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
  .creds span { font-size: 12px; font-weight: 500; background: var(--skin); border-radius: 999px; padding: 5px 11px; color: var(--ink-soft); }

  /* ФОРМАТ */
  .fmt { max-width: 760px; margin: 0 auto; background: var(--card); border-radius: var(--r); padding: 10px 30px; box-shadow: var(--sh-sm); }
  .fmt-row { display: flex; justify-content: space-between; align-items: baseline; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--line); }
  .fmt-row:last-child { border-bottom: 0; }
  .fmt-row b { font-family: 'Fraunces', serif; font-weight: 500; font-size: 19px; }

  /* ТАРИФЫ */
  .tf-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .tf { background: var(--card); border-radius: var(--r); padding: 32px 30px 34px; box-shadow: var(--sh-sm); display: flex; flex-direction: column; }
  .tf.featured { background: linear-gradient(165deg, #fffcf9, #f6e8dd); box-shadow: var(--sh); }
  .tf-badge {
    display: inline-block; align-self: flex-start; font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; color: #fff8f3; background: var(--caramel);
    border-radius: 999px; padding: 6px 14px; margin-bottom: 14px;
  }
  .tf-name { font-family: 'Fraunces', serif; font-size: 26px; }
  .tf-limit { font-size: 13px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sage); margin-top: 8px; }
  .tf-price { font-family: 'Fraunces', serif; font-size: 38px; color: var(--caramel); margin: 16px 0 20px; }
  .tf-feats { list-style: none; margin-bottom: 26px; flex: 1; }
  .tf-feats li { font-size: 15px; color: var(--ink-soft); padding: 10px 0 10px 26px; position: relative; border-bottom: 1px solid var(--line); }
  .tf-feats li::before { content: '✦'; position: absolute; left: 4px; top: 10px; color: var(--clay); font-size: 12px; }
  .tf .btn { width: 100%; }

  /* CTA */
  .cta-in {
    background: var(--caramel); color: #fff8f3; border-radius: 48px; padding: 76px 40px;
    text-align: center; position: relative; overflow: hidden; box-shadow: var(--sh);
  }
  .cta-in::before { content: ''; position: absolute; left: -90px; bottom: -140px; width: 420px; height: 420px; border-radius: 50%; background: rgba(255, 248, 243, 0.09); }
  .cta-in::after { content: ''; position: absolute; right: -70px; top: -150px; width: 340px; height: 340px; border-radius: 50%; background: rgba(255, 248, 243, 0.07); }
  .cta-in h2 { font-size: clamp(32px, 4.6vw, 56px); max-width: 18ch; margin: 20px auto 0; position: relative; }
  .cta-in p { color: rgba(255, 248, 243, 0.8); margin: 22px auto 34px; max-width: 46ch; position: relative; }
  .cta-in .btn { position: relative; }
  .cta-in .note { margin-top: 18px; font-size: 14px; color: rgba(255, 248, 243, 0.75); position: relative; }

  .ftr { padding: 30px 0; color: var(--ink-soft); font-size: 14px; }

  @media (max-width: 1080px) {
    .hero-grid { grid-template-columns: 1fr; gap: 44px; }
    .float.f1 { left: 10px; }
    .float.f2 { right: 6px; }
    .cards, .tf-grid { grid-template-columns: 1fr 1fr; }
    .ex-grid { grid-template-columns: 1fr 1fr; }
    .nav { display: none; }
  }
  @media (max-width: 720px) {
    .wrap { padding: 0 20px; }
    section { padding: 64px 0; }
    .nums-grid { grid-template-columns: 1fr 1fr; }
    .md-list ul, .cards, .tf-grid, .ex-grid { grid-template-columns: 1fr; }
    .ex-band { border-radius: 32px; }
    .cta-in { border-radius: 32px; padding: 54px 24px; }
  }
</style>
